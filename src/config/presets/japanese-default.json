  "parsing": {
    "task": {
      "checkboxPattern": "^\\s*[-*]\\s*\\[([ xX])\\]\\s*(.+)$",
      "priorityIndicators": {
        "p0": ["[P0]", "🔴", "【P0】", "❗"],
        "p1": ["[P1]", "🟡", "【P1】", "⚠️"],
        "p2": ["[P2]", "🟢", "【P2】", "ℹ️"]
      },
      "statusIndicators": {
        "completed": ["✅", "完了", "[x]", "[X]", "Done"],
        "pending": ["⏳", "保留", "[ ]", "Pending"],
        "inProgress": ["🔄", "進行中", "In Progress"]
      },
      "dueDatePatterns": [
        "期限[：:]\\s*(.+?)(?:\\s|$)",
        "Due[：:]\\s*(.+?)(?:\\s|$)",
        "~(\\d{1,2}/\\d{1,2})",
        "@(\\d{4}-\\d{2}-\\d{2})"
      ],
      "ownerPatterns": [
        "担当[：:]\\s*(.+?)(?:\\s|$)",
        "@(\\w+)",
        "Owner[：:]\\s*(.+?)(?:\\s|$)"
      ]
    },
    "feature": {
      "idPattern": "^(F\\d+|[A-Z]\\d+)\\s*[-:：]?\\s*",
      "fields": {
        "status": ["ステータス", "status", "状態"],
        "priority": ["優先度", "priority", "重要度"],
        "cycle": ["サイクル", "cycle", "フェーズ"],
        "owner": ["担当者", "owner", "責任者"]
      },
      "statusMapping": {
        "completed": ["完了", "Completed", "Done", "✅"],
        "inProgress": ["進行中", "In Progress", "開発中", "🔄"],
        "pending": ["保留", "Pending", "未着手", "⏳"]
      }
    },
    "blocker": {
      "resolvedIndicators": ["✅", "解決済み", "Resolved", "クローズ"],
      "unresolvedIndicators": ["❌", "未解決", "Unresolved", "オープン"],
      "inProgressIndicators": ["🔄", "対応中", "In Progress", "調査中"],
      "prioritySections": {
        "high": ["高優先度", "高", "High Priority", "クリティカル"],
        "medium": ["中優先度", "中", "Medium Priority", "通常"],
        "low": ["低優先度", "低", "Low Priority", "軽微"]
      },
      "impactPatterns": [
        "影響[：:]\\s*(.+?)(?:\\n|$)",
        "Impact[：:]\\s*(.+?)(?:\\n|$)"
      ]
    },
    "table": {
      "coordinationHeaders": ["調整事項", "Coordination", "協議"],
      "milestoneHeaders": ["マイルストーン", "Milestone", "目標"],
      "playbookHeaders": ["プレイブック", "Playbook", "手順"],
