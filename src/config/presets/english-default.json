  "parsing": {
    "task": {
      "checkboxPattern": "- \\[([ x])\\]",
      "priorityIndicators": {
        "p0": ["⏫", "#P0", "[P0]", "🔴", "critical", "urgent", "blocker"],
        "p1": ["🔼", "#P1", "[P1]", "🟡", "high", "important"],
        "p2": ["🔽", "#P2", "[P2]", "🟢", "low", "minor", "nice-to-have"]
      },
      "statusIndicators": {
        "completed": ["[x]", "✅", "DONE", "done", "complete", "completed", "finished"],
        "pending": ["[ ]", "⬜", "TODO", "todo", "pending", "not started"],
        "inProgress": ["[/]", "🔄", "WIP", "wip", "in progress", "working", "started"]
      },
      "dueDatePatterns": [
        "📅 (\\d{4}-\\d{2}-\\d{2})",
        "@due\\((.*?)\\)",
        "due[:\\s]*(\\d{4}-\\d{2}-\\d{2})",
        "deadline[:\\s]*(\\d{4}-\\d{2}-\\d{2})"
      ],
      "ownerPatterns": [
        "👤 (\\w+)",
        "@(\\w+)",
        "owner[:\\s]*(\\w+)",
        "assignee[:\\s]*(\\w+)"
      ]
    },
    "feature": {
      "idPattern": "[A-Z]+-?\\d+",
      "fields": {
        "status": ["status", "Status", "state", "State"],
        "priority": ["priority", "Priority", "importance"],
        "cycle": ["cycle", "Cycle", "sprint", "Sprint", "iteration"],
        "owner": ["owner", "Owner", "assignee", "Assignee"]
      },
      "statusMapping": {
        "completed": ["Complete", "Completed", "Done", "Shipped", "Released", "Closed"],
        "inProgress": ["In Progress", "WIP", "Active", "Development", "Working", "Started"],
        "pending": ["Pending", "TODO", "Planned", "Backlog", "Not Started", "Open"]
      }
    },
    "blocker": {
      "resolvedIndicators": ["✅", "Resolved", "Fixed", "Closed", "Done"],
      "unresolvedIndicators": ["⚠️", "Open", "Unresolved", "Active", "Blocking"],
      "inProgressIndicators": ["🔄", "In Progress", "Working", "Investigating"],
      "prioritySections": {
        "high": ["High Priority", "Critical", "P0", "Urgent", "Blocker"],
        "medium": ["Medium Priority", "P1", "Normal", "Important"],
        "low": ["Low Priority", "P2", "Minor", "Nice to have"]
      },
      "impactPatterns": [
        "Impact[:\\s]*(.*)",
        "Affects[:\\s]*(.*)",
        "Blocking[:\\s]*(.*)"
      ]
    },
    "table": {
      "coordinationHeaders": ["Category", "Content", "Topic", "Discussion", "Item"],
      "milestoneHeaders": ["Milestone", "Date", "Target", "Deadline"],
      "playbookHeaders": ["Item", "Target", "Goal", "Objective", "Metric"],
      "columnAliases": {
        "category": ["Category", "Type", "Group", "Section"],
        "content": ["Content", "Description", "Details", "Notes"],
        "priority": ["Priority", "Importance", "Urgency"],
        "owner": ["Owner", "Assignee", "Responsible", "Lead"],
        "deadline": ["Deadline", "Due", "Due Date", "Target Date"],
        "status": ["Status", "State", "Progress"],
        "date": ["Date", "When", "Scheduled"],
        "name": ["Name", "Title", "Task", "Item"],
        "target": ["Target", "Goal", "Objective"],
        "current": ["Current", "Actual", "Progress"],
        "percentage": ["Progress", "%", "Completion", "Percent"],
        "risk": ["Risk", "Risks", "Blockers"]
      }
    }
  },
  "reports": {
    "weekly": {
      "enabled": true,
      "filename": "Weekly_W{week}_{date}.xlsx",
      "metadata": {
        "author": "",
        "title": "Weekly Report",
        "subject": "Weekly Progress Report"
      }
    },
    "quarterly": {
