  "parsing": {
    "task": {
      "checkboxPattern": "- \\[([ x])\\]",
      "priorityIndicators": {
        "p0": ["⏫", "#P0", "[P0]", "🔴", "긴급", "critical"],
        "p1": ["🔼", "#P1", "[P1]", "🟡", "높음", "high"],
        "p2": ["🔽", "#P2", "[P2]", "🟢", "낮음", "low"]
      },
      "statusIndicators": {
        "completed": ["[x]", "✅", "완료", "DONE", "done", "complete"],
        "pending": ["[ ]", "⬜", "대기", "TODO", "todo", "pending"],
        "inProgress": ["[/]", "🔄", "진행중", "WIP", "wip", "진행"]
      },
      "dueDatePatterns": [
        "📅 (\\d{4}-\\d{2}-\\d{2})",
        "@due\\((.*?)\\)",
        "마감[:\\s]*(\\d{4}-\\d{2}-\\d{2})"
      ],
      "ownerPatterns": [
        "👤 (\\w+)",
        "@(\\w+)",
        "담당[:\\s]*(\\w+)"
      ]
    },
    "feature": {
      "idPattern": "[AB]\\d+",
      "fields": {
        "status": ["status", "상태", "Status"],
        "priority": ["priority", "우선순위", "Priority"],
        "cycle": ["cycle", "사이클", "Cycle"],
        "owner": ["owner", "담당자", "Owner"]
      },
      "statusMapping": {
        "completed": ["완료", "Complete", "Completed", "Done", "Shipped"],
        "inProgress": ["진행중", "진행", "In Progress", "WIP", "Active", "Development"],
        "pending": ["대기", "계획", "Pending", "TODO", "Planned", "Backlog"]
      }
    },
    "blocker": {
      "resolvedIndicators": ["✅", "해결", "Resolved", "Fixed", "Closed"],
      "unresolvedIndicators": ["⚠️", "미해결", "Open", "Unresolved", "Active"],
      "inProgressIndicators": ["🔄", "진행중", "In Progress", "Working"],
      "prioritySections": {
        "high": ["높음 우선순위", "High Priority", "Critical", "P0", "긴급"],
        "medium": ["중간 우선순위", "Medium Priority", "P1", "Normal"],
        "low": ["낮음 우선순위", "Low Priority", "P2", "Minor"]
      },
      "impactPatterns": [
        "영향[:\\s]*(.*)",
        "Impact[:\\s]*(.*)",
        "Affects[:\\s]*(.*)"
      ]
    },
    "table": {
      "coordinationHeaders": ["구분", "협의내용", "Category", "Content", "협의", "항목"],
      "milestoneHeaders": ["마일스톤", "Milestone", "날짜", "Date", "이정표"],
      "playbookHeaders": ["항목", "Item", "목표", "Target", "플레이북"],
      "columnAliases": {
        "category": ["구분", "Category", "분류", "Type"],
        "content": ["협의내용", "Content", "내용", "Description"],
        "priority": ["우선순위", "Priority", "중요도"],
        "owner": ["담당자", "Owner", "담당", "Assignee"],
        "deadline": ["마감일", "Deadline", "Due", "기한"],
        "status": ["상태", "Status", "진행상태"],
        "date": ["날짜", "Date", "일자"],
        "name": ["이름", "Name", "작업명", "Title"],
        "target": ["목표", "Target", "Goal"],
        "current": ["현재", "Current", "실적"],
        "percentage": ["진척률", "Progress", "%", "퍼센트"],
        "risk": ["위험", "Risk", "리스크"]
      }
    }
  },
