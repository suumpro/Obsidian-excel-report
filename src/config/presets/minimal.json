  "parsing": {
    "task": {
      "checkboxPattern": "^\\s*[-*]\\s*\\[([ xX])\\]\\s*(.+)$",
      "priorityIndicators": {
        "p0": ["[P0]", "P0"],
        "p1": ["[P1]", "P1"],
        "p2": ["[P2]", "P2"]
      },
      "statusIndicators": {
        "completed": ["[x]", "[X]", "Done"],
        "pending": ["[ ]", "Pending"],
        "inProgress": ["WIP", "In Progress"]
      },
      "dueDatePatterns": [
        "Due:\\s*(.+?)(?:\\s|$)",
        "@(\\d{4}-\\d{2}-\\d{2})"
      ],
      "ownerPatterns": [
        "@(\\w+)",
        "Owner:\\s*(.+?)(?:\\s|$)"
      ]
    },
    "feature": {
      "idPattern": "^(F\\d+)\\s*[-:]?\\s*",
      "fields": {
        "status": ["status", "Status"],
        "priority": ["priority", "Priority"],
        "cycle": ["cycle", "Cycle"],
        "owner": ["owner", "Owner"]
      },
      "statusMapping": {
        "completed": ["Done", "Completed"],
        "inProgress": ["WIP", "In Progress"],
        "pending": ["Pending", "Todo"]
      }
    },
    "blocker": {
      "resolvedIndicators": ["Resolved", "Fixed", "Done"],
      "unresolvedIndicators": ["Open", "Unresolved"],
      "inProgressIndicators": ["WIP", "In Progress"],
      "prioritySections": {
        "high": ["High", "Critical"],
        "medium": ["Medium", "Normal"],
        "low": ["Low", "Minor"]
      },
      "impactPatterns": [
        "Impact:\\s*(.+?)(?:\\n|$)"
      ]
    },
    "table": {
      "coordinationHeaders": ["Coordination"],
      "milestoneHeaders": ["Milestone"],
      "playbookHeaders": ["Playbook"],
      "columnAliases": {
        "category": ["Category", "Cat"],
        "content": ["Content", "Details"],
        "priority": ["Priority", "Pri"],
        "owner": ["Owner"],
        "deadline": ["Due", "Deadline"],
        "status": ["Status"],
        "date": ["Date"],
        "name": ["Name", "Task"],
        "target": ["Target", "Goal"],
        "current": ["Current"],
        "percentage": ["%", "Progress"],
        "risk": ["Risk"]
      }
    }
  }
